# Telegram Bot
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Admin
ADMIN_ID=YOUR_ADMIN_ID_HERE

# MongoDB
MONGO_URI=mongodb://localhost:27017
DB_NAME=somly_ai_bot

# Groq API Keys (Multiple keys for automatic rotation and avoiding limits)
# QOIDALAR:
# - API kalitlarni vergul (,) bilan ajratib yozing, bo'sh joy qoldirmang.
# - Siz 5 ta yoki undan ko'p API kalit kiritishingiz mumkin.
# - Bot birinchi kalitni ishlatadi. Agar uning limiti tugasa yoki xato bersa,
#   avtomatik tarzda ikkinchi kalitga o'tadi va hokazo (Round-Robin tizimi).
# MISOL UCHUN:
GROQ_API_KEYS=gsk_firstKey123,gsk_secondKey456,gsk_thirdKey789,gsk_fourthKey101,gsk_fifthKey112

# Optional Settings
GROQ_MODEL=llama-3.3-70b-versatile
